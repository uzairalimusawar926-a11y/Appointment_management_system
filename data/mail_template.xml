<odoo>
    <record id="appointment_confirmation_email_template_id" model="mail.template">
        <field name="name">Appointment Confirmation</field>
        <field name="model_id" ref="calendar.model_calendar_event"/>
        <field name="subject">Appointment Confirmed</field>
        <field name="email_from">{{ (object.partner_id.email_formatted if object.partner_id else user.email_formatted) }}</field>
        <field name="email_to">{{object.partner_id.email or ''}}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Hello <t t-out="object.partner_id.name or ''"/><br/><br/>
                    Your appointment has been <strong>confirmed</strong>
                </p>
            </div>
        </field>
    </record>

</odoo>
