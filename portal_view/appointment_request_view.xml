                                    <br/>
                                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
                                        <img t-att-src="appointment_img" alt="Service Image" width="64" height="64"
                                             style="border-radius: 8px;"/>
                                        <div>
                                            <h5 style="margin: 0;">
                                                <t t-esc="appointment_name"/>
                                            </h5>
                                            <span style="font-size: 13px; color: #666;">
                                                <i class="fa fa-map-marker"></i>
                                                <t t-esc="appointment_location"/>
                                            </span>
                                        </div>
                                    </div>

                                    <div class="p-3 border rounded shadow-sm">
                                        <h6 class="fw-bold mb-3">Booking Info</h6>

                                        <div class="row mb-2">
                                            <!--                                            <div class="col-6">-->
                                            <!--&lt;!&ndash;                                                <strong>Service Time</strong>&ndash;&gt;-->
                                            <!--&lt;!&ndash;                                                <br/>&ndash;&gt;-->
                                            <!--&lt;!&ndash;                                                <t t-esc="appointment_service_time"/>&ndash;&gt;-->
                                            <!--                                            </div>-->
                                            <div class="col-6">
                                                <strong>Appointment Type</strong>
                                                <br/>
                                                <t t-esc="appointment_type"/>
                                            </div>

                                            <div class="col-6">
                                                <strong>Date</strong>
                                                <br/>
                                                <t t-if="request_date">
                                                    <t t-esc="request_date"/>
                                                </t>
                                                <t t-else="">
                                                    <span t-esc="datetime.datetime.now().strftime('%A, %d %B %Y')"/>
                                                </t>
                                            </div>
                                        </div>

                                        <div class="row mb-2">
                                            <div class="col-6">
                                                <strong>Time</strong>
                                                <br/>
                                                <t t-esc="selected_slot_name"/>
                                            </div>
                                            <div class="col-6">
                                                <strong>Time Zone</strong>
                                                <br/>
                                                <t t-esc="user_timezone"/>
                                            </div>
                                        </div>


                                    </div>
                                </div>

                                <!-- Right Column: Appointment Form -->
                                <div style="flex: 1; min-width: 300px; padding: 40px;">
                                    <h4 style="margin-bottom: 16px;">Enter Details</h4>

                                    <div class="mb-3">
                                        <label for="contact_name" class="form-label">Name
                                            <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="contact_name"
                                                   name="contact_name" placeholder="Enter Your Name" required="1"/>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="email" class="form-label">Email
                                            <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <input type="email" class="form-control" id="email" name="email"
                                                   placeholder="Enter Your Email" required="1"/>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="mobile" class="form-label">Mobile Number
                                            <span class="text-danger">*</span>
                                        </label>
                                        <div class="input-group">
                                            <input type="tel" class="form-control" id="mobile" name="mobile"
                                                   placeholder="Enter Your Mobile Number" required="1"/>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="description" class="form-label">
                                            Kindly share anything that could help us prepare ahead of the meeting.
                                        </label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="description" name="description"
                                                   placeholder="Enter Details"/>
                                        </div>
                                    </div>
                                    <div style="text-align: right;">
                                        <button type="submit" class="btn btn-primary">Book Appointment</button>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </form>

                </div>
            </div>
        </t>
    </template>

    <template id="website_appointment_request_thank_you" name="Order Sucess" customize_show="True">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="oe_structure" id="oe_structure_website_form_contact_us_thanks_1"/>
                <div class="container mt-4">
                    <div class="row">
                        <div class="col-lg-7 col-xl-6 mr-lg-auto oe_structure">
                            <section class="pt40 s_text_block pb40 o_colored_level o_cc o_cc1"
                                     data-snippet="s_text_block" data-name="Text">
                                <div class="container">
                                    <span class="d-block fa fa-4x fa-thumbs-up mx-auto rounded-circle bg-primary"/>
                                    <br/>
                                    <h1 class="text-center">Thank You!</h1>
                                    <div class="pb16 pt16 s_hr" data-snippet="s_hr" data-name="Separator">
                                        <hr class="mx-auto border-top w-50 border-dark text-center"/>
                                    </div>
                                    <h5 class="text-center">
                                        <span class="fa fa-check-circle"/>
                                        <span>Your Appointment has been create
                                            <b>successfully</b>
                                            <br/>
                                            Request
                                            Number is
                                            <b>
                                                <t t-esc="reference_number"/>
                                            </b>
                                        </span>
                                    </h5>
                                    <p class="text-center">We will get back to you shortly.</p>
                                </div>
                            </section>
                        </div>
                        <div class="col-lg-4">
                            <ul class="list-unstyled mb-0 pl-2">
                                <li>
                                    <h3>
                                        <span t-field="dev_company.name"/>
                                    </h3>
                                </li>
                                <li>
                                    <i class="fa fa-map-marker fa-fw mr-2"/>
                                    <span class="o_force_ltr">
                                        <span t-field="dev_company.street"/>
                                        <t t-if="dev_company.street2">,
                                            <span t-field="dev_company.street2"/>
                                        </t>
                                    </span>
                                </li>
                                <li>
                                    <i class="fa fa-phone fa-fw mr-2"/>
                                    <span class="o_force_ltr">
                                        <span t-field="dev_company.phone"/>
                                    </span>
                                </li>
                                <li>
                                    <i class="fa fa-1x fa-fw fa-envelope mr-2"/>
                                    <span t-field="dev_company.email"/>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="oe_structure" id="oe_structure_website_form_contact_us_thanks_2"/>
            </div>
        </t>
    </template>

</odoo>
