                color: #999 !important;
                pointer-events: none;
                cursor: not-allowed;
                opacity: 0.6;
                }

            </style>

            <script type="text/javascript">
                <![CDATA[
    document.addEventListener('DOMContentLoaded', function () {
        var calendarEl = document.getElementById('calendar');
        var previouslySelected = null;

        function markPastDatesReadonly() {
            var today = new Date();
            today.setHours(0, 0, 0, 0);

            document.querySelectorAll('[data-date]').forEach(function (cell) {
                var cellDate = new Date(cell.getAttribute('data-date'));
                if (cellDate < today) {
                    cell.classList.add('fc-past-readonly');
                    cell.setAttribute('title', 'Unavailable');
                }
            });
        }

        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            dateClick: function (info) {
                var clickedDate = new Date(info.dateStr);
                var today = new Date();
                today.setHours(0, 0, 0, 0);

                if (clickedDate < today) {
                    return;
                }

                if (previouslySelected) {
                    var oldCell = document.querySelector('[data-date="' + previouslySelected + '"]');
                    if (oldCell) {
                        oldCell.classList.remove('selected-date-highlight');
                    }
                }

                var newCell = document.querySelector('[data-date="' + info.dateStr + '"]');
                if (newCell) {
                    newCell.classList.add('selected-date-highlight');
                }

                previouslySelected = info.dateStr;
                $('#request_date').val(info.dateStr).trigger('change');
            },
            eventClick: function (info) {
                $('#request_date').val(info.event.startStr).trigger('change');
            },
            datesSet: function () {
                // Runs every time view or date range changes (month navigation, etc.)
                setTimeout(markPastDatesReadonly, 0);
            }
        });

        calendar.render();
    });
    ]]>
            </script>


