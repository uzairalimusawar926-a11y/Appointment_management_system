<?xml version="1.0" encoding="UTF-8"?>
<templates id="appointmentDashboard" xml:space="preserve">
	<t t-name="appointmentDashboard">
		<div style=" overflow-y:scroll; height:100%; background-color:#fbf8fa">
			<div class="mx-5">
				<div class="row gx-0 mt-3">
					<div class="col-12 d-flex justify-content-end">
						<button id="downloadBtn" t-on-click="(e) => this.downloadReport(e)" class="btn p-2" style="background-color: #2a34bb; color: #FFFFFF;">
							<i class="fa fa-file-pdf-o p-1" aria-hidden="true" style="color: #FFFFFF;">
							</i>
							Print
						</button>
					</div>
				</div>
			</div>
			<div class="mx-5 " id="dashboard">
				<t t-call="appointment_filters" />
				<t t-call="appointment_counters" />
				<t t-call="appointment_charts" />
			</div>
		</div>
	</t>
	<t t-name="appointment_filters">
		<div class="card mt-4 filters">
			<div class="row p-2 m-2 gx-0 gy-2">
				<div class="col-lg-1 d-flex my-auto justify-content-center">
					<img t-att-src="'data:image/png;base64,' + state.user_img.value" class="css-shadow" />
				</div>
				<div class="col-lg-4 pl-1 my-auto">
					<h2>
						<t t-esc="greetings" />
						,
						<t t-esc="state.user_name.value" />
						.
					</h2>
					<h4>
						Welcome to your Appointment Dashboard.
					</h4>
				</div>
				<div class="col-lg-7">
					<div class="row gy-2">
						<div class="col-lg-3 m-0">
							<label for="user_selection" class="form-label fw-bolder">
								User
							</label>
							<select class="form-select" id="user_selection" t-on-change="(ev) => this._onchangeAppointmentFilter(ev)">
								<option value="all">
									All User
								</option>
							</select>
						</div>
						<div class="col-lg-3 m-0">
							<label for="request_date" class="form-label fw-bolder">
								Date
							</label>
							<select class="form-select" id="request_date" t-on-change="(ev) => this._onchangeAppointmentFilter(ev)">
								<option value="0">
									Today
								</option>
								<option value="7">
									Last 7 Days
								</option>
								<option value="28">
									Last 28 Days
								</option>
								<option value="90">
									Last 90 Days
								</option>
								<option value="365">
									Last 365 Days
								</option>
								<option value="all">
									Lifetime
								</option>
							</select>
						</div>
						
					</div>
				</div>
			</div>
		</div>
	</t>
	<t t-name="appointment_counters">
		<div class="mt-3 mb-0">
			<table class="table text-center align-middle" style="table-layout: fixed; width: 100%;">
				<tbody>
					<tr>
						<!-- Total Appointment -->
						<td id="all_appointment_id" t-on-click="(e) => this.action_all_appointment_counter(e)" style="cursor:pointer; width:20%;">
							<div class="card box" style="border-radius: 0;">
								<div class="card-body box-body p-2">
									<div class="fw-semibold mb-2 text-center py-1" style="margin:-7px;font-size: 15px; background-color: #2a34bb; color: white; border-radius: 0;">
										Total Appointment
									</div>
									<div class="d-flex align-items-center  pt-2">
										<img src="/dev_appointment/static/src/img/Appointment Icon.png" style="height: 40px; width: 40px;margin-left:10px;" />
										<span class="fw-bold ps-2" style="font-size: 23px; color: #171d68;margin-left:35px;">
											<t t-esc="this.state.total_appointment.length" />
										</span>
									</div>
								</div>
							</div>
						</td>
						<!-- Draft Appointment -->
						<td id="draft_appointment_id" t-on-click="(e) => this.action_all_appointment_counter(e)" style="cursor:pointer;width:20%;">
							<div class="card box" style="border-radius: 0;">
								<div class="card-body box-body p-2">
									<div class="fw-semibold mb-2 text-center py-1" style="margin:-7px;font-size: 15px; background-color: #2a34bb; color: white; border-radius: 0;">
										Draft Appointment
									</div>
									<div class="d-flex align-items-center  pt-2">
										<img src="/dev_appointment/static/src/img/Appointment Icon.png" style="height:40px; width: 40px;margin-left:10px;" />
										<span class="fw-bold ps-2" style="font-size: 23px; color: #171d68; margin-left:35px;">
											<t t-esc="this.state.draft_appointment_list.length" />
										</span>
									</div>
								</div>
							</div>
						</td>
						<!-- Confirm Appointment -->
						<td id="confirm_appointment_id" t-on-click="(e) => this.action_all_appointment_counter(e)" style="cursor:pointer;width:20%;">
							<div class="card box" style="border-radius: 0;">
								<div class="card-body box-body p-2">
									<div class="fw-semibold mb-2 text-center py-1" style="margin:-7px;font-size: 15px; background-color: #2a34bb; color: white; border-radius: 0;">
										Confirm Appointment
									</div>
									<div class="d-flex align-items-center  pt-2">
										<img src="/dev_appointment/static/src/img/Appointment Icon.png" style="height:40px; width: 40px;margin-left:10px;" />
										<span class="fw-bold ps-2" style="font-size: 23px; color: #171d68;margin-left:35px;">
											<t t-esc="this.state.confirm_appointment_list.length" />
										</span>
									</div>
								</div>
							</div>
						</td>
						<!-- Done Appointment -->
						<td id="done_appointment_id" t-on-click="(e) => this.action_all_appointment_counter(e)" style="cursor:pointer;width:20%;">
							<div class="card box" style="border-radius: 0;">
								<div class="card-body box-body p-2">
									<div class="fw-semibold mb-2 text-center py-1" style="margin:-7px;font-size: 15px; background-color: #2a34bb; color: white; border-radius: 0;">
										Done Appointment
									</div>
									<div class="d-flex align-items-center  pt-2">
										<img src="/dev_appointment/static/src/img/Appointment Icon.png" style="height:40px; width: 40px; margin-left:10px;" />
										<span class="fw-bold ps-2" style="font-size: 23px; color: #171d68;margin-left:35px;">
											<t t-esc="this.state.done_appointment_list.length" />
										</span>
									</div>
								</div>
							</div>
						</td>
						<!-- Cancel Appointment -->
						<td id="cancel_appointment_id" t-on-click="(e) => this.action_all_appointment_counter(e)" style="cursor:pointer;">
							<div class="card box" style="border-radius: 0;">
								<div class="card-body box-body p-2">
									<div class="fw-semibold mb-2 text-center py-1" style="margin:-7px;font-size: 15px; background-color: #2a34bb; color: white; border-radius: 0;">
										Cancel Appointment
									</div>
									<div class="d-flex align-items-center pt-2">
										<img src="/dev_appointment/static/src/img/Appointment Icon.png" style="height:40px; width: 40px;margin-left:10px;" />
										<span class="fw-bold ps-2" style="font-size: 23px; color: #171d68;margin-left:35px;">
											<t t-esc="this.state.cancel_appointment_list.length" />
										</span>
									</div>
								</div>
							</div>
						</td>
					</tr>
				</tbody>
			</table>
		</div>
	</t>
	<t t-name="appointment_charts">
		<div class="mt-5 col-12">
			<div class="row gy-2 d-flex align-items-stretch">
				<div class="col-lg-6 col-md-5 col-6">
					<div class="card table-card h-100" style="overflow-x:clip;">
						<div class="card-header">
							<div class="row">
								<div class="col-6">
									<label for="month_chart_selection" style="color: #171d68;" class="form-label fw-bolder">
										Chart Type
									</label>
									<select id="month_chart_selection" style="color:#171d68" class="form-select form-control pull-left" t-on-change="(ev) => this.month_wise_appointmentChart(ev)">
										<option value="bar">
											Bar
										</option>
										<option value="line">
											Line
										</option>
										
										
									</select>
								</div>
								
							</div>
						</div>
						<div class="card-title text-center p-3" style="font-weight:600; font-size:20px;">
							<div class="row">
								<div class="col-2">
								</div>
								<div class="col-8" style="color: #171d68;">
									Month Wise Appointment
								</div>
								<div class="col-2">
									<i class="fa fa-download" id="month_wise_appointment_chart_data_btn" style="cursor: pointer;color:#171d68;" aria-hidden="true" t-on-click="(e) => this._downloadChart(e)" />
								</div>
							</div>
						</div>
						<div class="card-body text-center">
							<canvas id="month_wise_appointment_chart_data" height="300" />
						</div>
					</div>
				</div>
				<div class="col-lg-6 col-md-5 col-6">
					<div class="card table-card h-100" style="overflow-x:clip;">
						<div class="card-header">
							<div class="row">
								<div class="col-6">
									<label for="service_chart_selection" style="color: #171d68;" class="form-label fw-bolder">
										Chart Type
									</label>
									<select id="service_chart_selection" style="color:#171d68" class="form-select form-control pull-left" t-on-change="(ev) => this.top_demanded_service_chart(ev)">
										<option value="doughnut">
											Doughnut
										</option>
										<option value="line">
											Line
										</option>
										<option value="pie">
											Pie
										</option>
										<option value="bar">
											Bar
										</option>
									</select>
								</div>
								<div class="col-6">
									<label for="service_range_selection" style="color: #171d68;" class="form-label fw-bolder">
										Range
									</label>
									<select class="form-select" style="color:#171d68" id="service_range_selection" t-on-change="(ev) => this.top_demanded_service_chart(ev)">
										<option value="5">
											5
										</option>
										<option value="10">
											10
										</option>
										<option value="15">
											15
										</option>
										<option value="20">
											20
										</option>
										
									</select>
								</div>
							</div>
						</div>
						<div class="card-title text-center p-3" style="font-weight:600; font-size:20px;">
							<div class="row">
								<div class="col-2">
								</div>
								<div class="col-8" style="color: #171d68;">
									Most Demanded Service 
								</div>
								<div class="col-2">
									<i class="fa fa-download" id="top_demanded_service_chart_btn" style="cursor: pointer;color:#171d68" aria-hidden="true" t-on-click="(e) => this._downloadChart(e)" />
								</div>
							</div>
						</div>
						<div class="card-body text-center">
							<canvas id="top_demanded_service_chart" />
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="mt-5 col-12">
			<div class="row mt-3 gy-2">
				<div class="col-lg-6 col-md-6 col-12 h-100">
					<div class="card table-card" style="overflow-x:clip;">
						<div class="card-header">
							<div class="row">
								<div class="col-6">
									<label for="service_revenue_chart_selection" class="form-label fw-bolder" style="color: #171d68;">
										Chart Type
									</label>
									<select id="service_revenue_chart_selection" style="color:#171d68" class="form-select form-control pull-left" t-on-change="(ev) => this.top_revenue_service_chart(ev)">
										<option value="pie">
											Pie
										</option>
										<option value="line">
											Line
										</option>
										<option value="doughnut">
											Doughnut
										</option>
										<option value="bar">
											Bar
										</option>
									</select>
								</div>
								<div class="col-6">
									<label for="service_revenue_range_selection" class="form-label fw-bolder" style="color: #171d68;">
										Range
									</label>
									<select class="form-select" style="color:#171d68" id="service_revenue_range_selection" t-on-change="(ev) => this.top_revenue_service_chart(ev)">
										<option value="5">
											5
										</option>
										<option value="10">
											10
										</option>
										<option value="15">
											15
										</option>
										<option value="20">
											20
										</option>
										
									</select>
								</div>
							</div>
						</div>
						<div class="card-title text-center p-3" style="font-weight:600; font-size:23px;">
							<div class="row">
								<div class="col-10" style="color: #171d68;">
									Top Revenue by Service
								</div>
								<div class="col-2">
									<i class="fa fa-download" style="cursor: pointer;color:#171d68" id="top_revenue_by_service_chart_btn" aria-hidden="true" t-on-click="(e) => this._downloadChart(e)">
									</i>
								</div>
							</div>
						</div>
						<div class="card-body text-center">
							<canvas id="top_revenue_by_service_chart" class="bar-chart" />
						</div>
					</div>
				</div>
				<div class="col-lg-6">
					<div class="card table-card table-responsive">
						<div class="card-header table-header row-12">
							<div class="d-flex justify-content-between align-items-center w-100">
								<span class="fw-bold ms-3" style="color: #171d68;">
									Upcoming Appointment
								</span>
								<div class="d-flex align-items-center me-3">
									<label for="appointment_upcoming_selection" class="me-2 fw-bold" style="color: #171d68;">
										Duration:
									</label>
									<select class="form-select" style="color:#171d68" id="appointment_upcoming_selection" t-on-change="(ev) => this.render_upcoming_appointment_list(this.state.rowsPerPage, this.state.current_upcoming_appointment_page)">
										<option value="0">
											Today
										</option>
										<option value="28">
											Next 28 Days
										</option>
										<option value="90">
											Next 90 Days
										</option>
										<option value="365">
											Next 365 Days
										</option>
									</select>
								</div>
							</div>
						</div>
						<table id="all_upcoming_appointment_lst" class="table table-hover">
							<thead>
								<tr>
									<th>
										Name
									</th>
									<th>
										Start
									</th>
									<th>
										Service
									</th>
									<th>
										Status
									</th>
									<th>
									</th>
									<th>
									</th>
								</tr>
							</thead>
							<tbody>
							</tbody>
						</table>
						<t t-if="this.state.upcoming_appointment_list_length">
							<div class="d-flex align-items-center justify-content-center text-primary m-2">
								<i class="fa fa-arrow-circle-left fa-2x" style="color:#2a34bb" aria-hidden="true" id="upcoming_prev_button" t-on-click="(e) => this.upcomingPrevPage(e)">
								</i>
								<span style="font-weight:600; font-size:15px; margin:0px 5px 0px 5px;color:#2a34bb">
									Page
									<t t-esc="this.state.current_upcoming_appointment_page" />
									of
									<t t-esc="Math.ceil(this.state.upcoming_appointment_list_length/this.state.rowsPerPage)" />
								</span>
								<i class="fa fa-arrow-circle-right fa-2x" style="color:#2a34bb" id="upcoming_next_button" aria-hidden="true" t-on-click="(e) => this.upcomingNextPage(e)">
								</i>
							</div>
						</t>
					</div>
				</div>
			</div>
		</div>
		<div class="row">
			<div class="col-12" style="margin:20px;">
			</div>
		</div>
	</t>
</templates>
