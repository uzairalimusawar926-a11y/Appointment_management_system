<odoo>
    <!-- Tree View -->
    <record id="view_appointment_tree" model="ir.ui.view">
        <field name="name">appointment.appointment.tree</field>
        <field name="model">appointment.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="appointment_type"/>
                <field name="location"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
                <field name="fees"/>
            </list>
        </field>
    </record>

    <record id="view_appointment_form" model="ir.ui.view">
        <field name="name">appointment.appointment.form</field>
        <field name="model">appointment.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_slots_appointment" type="object" string="Generate Slots"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div style="display: flex; align-items: center;">
                        <div style="flex-grow: 1; margin-right: 20px;">
                            <label for="name" style="font-size: 18px; font-weight: bold;">Name</label>
                            <field name="name" style="font-size: 22px; height: 40px; font-weight: bold; width: 100%;" required="1"/>
                        </div>

                        <div>
                            <field name="image_1920" widget="image" class="oe_avatar"
                                   options="{'preview_image': 'image_1920'}" nolabel="1"
                                   style="width: 120px; height: 120px; border-radius: 8px;"/>
                        </div>
                    </div>
                    <group string="Details">
                        <group>
                            <field name="appointment_type"/>
                            <field name="is_user"/>
                            <div invisible="is_user == False">
                                <label for="user_ids" string="Users:" class="fw-bold"/>
                                <field name="user_ids" widget="many2many_tags" string="Users" class="oe_inline"/>
                                <button name="update_user" type="object" string="Update User"
                                        class="btn-primary oe_inline"/>
                            </div>
                        </group>
                        <group>
                            <field name="tz"/>
                            <field name="location"/>
                            <field name="fees"/>
                        </group>
                    </group>


                    <!-- ⏰ Timing Group (Below Details) -->
                    <group string="Timing">
                        <group>
                            <span class="fw-bold text-nowrap">Days</span>
                            <div>
                                <widget name="calendar_week_days"/>
                            </div>
                            <label for="slot_duration" string="Slot Duration"/>
                            <div class="oe_inline" style="display: flex; align-items: center;">
                                <field name="slot_duration" nolabel="1" style="width: 60px; margin-right: 4px;"/>
                                <span>min</span>
                            </div>
                            <label for="buffer_time" string="Buffer Time"/>
                            <div class="oe_inline" style="display: flex; align-items: center;">
                                    <field name="buffer_time" nolabel="1" style="width: 60px; margin-right: 4px;"/>
                                    <span>min</span>
                            </div>
                        </group>
                        <group>
                            <field name="start_time" widget="float_time" placeholder="24 hours format"
                                   help="Please Enter 24 hours format"/>
                            <field name="end_time" widget="float_time" placeholder="24 hours format"
                                   help="Please Enter 24 hours format"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Generated Slots">
                            <field name="time_slot_ids">
                                <list>
                                    <field name="day" string="Days"/>
                                    <field name="total_slot_count" string="Total Slots"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action and Menu -->
    <record id="action_appointment_appointment" model="ir.actions.act_window">
        <field name="name">Appointment</field>
        <field name="res_model">appointment.appointment</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_services_config" name="Configuration" parent="menu_appointment_root" sequence="20"/>

    <menuitem id="menu_appointment_appointment" name="Service" parent="menu_services_config"
              action="action_appointment_appointment" sequence="1"/>
</odoo>
