<odoo>

    <record id="view_time_slot_search" model="ir.ui.view">
        <field name="name">time.slot.search</field>
        <field name="model">time.slot</field>
        <field name="arch" type="xml">
            <search>
                <field name="service_id"/>
                <group expand="1" string="Group By">
                    <filter name="group_by_service" string="Service" context="{'group_by': 'service_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_time_slot_tree" model="ir.ui.view">
        <field name="name">time.slot.tree</field>
        <field name="model">time.slot</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="day" string="Day"/>
                <field name="slot_duration" string="Duration"/>
                <field name="start_time" widget="float_time" string="Start Time"/>
                <field name="end_time" widget="float_time" string="End Time"/>
            </list>
        </field>
    </record>

    <record id="view_time_slot_form" model="ir.ui.view">
        <field name="name">time.slot.form</field>
        <field name="model">time.slot</field>
        <field name="arch" type="xml">
            <form create="false">
<!--                <header>-->
<!--                    <button name="action_generate_slots" type="object" string="Generate Slots" class="btn-primary"/>-->
<!--                </header>-->
                <sheet>
                    <group>
                        <group>
<!--                            <field name="user_ids" widget="many2many_tags"/>-->
                            <field name="slot_duration"/>
                            <field name="start_time" widget="float_time"/>
                            <field name="end_time" widget="float_time"/>
                        </group>
                        <group invisible="1">
                            <field name="active"/>
                        </group>

                    </group>

                    <notebook>
                        <page string="Generated Slots">
                            <field name="slot_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="user_ids" widget="many2many_tags" domain="[('id', 'in', appointment_user_ids)]"/>
                                    <field name="day"/>
                                    <field name="service_id" invisible="1" nolabel="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_time_slot" model="ir.actions.act_window">
        <field name="name">Time Slots</field>
        <field name="res_model">time.slot</field>
        <field name="view_mode">search,list,form</field>
    </record>


    <menuitem id="menu_time_slot" name="Time Slots" parent="dev_appointment.menu_services_config"
              action="action_time_slot" sequence="6"/>

</odoo>
